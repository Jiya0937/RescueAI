# ==========================================
# RescueAI Backend Configuration
# ==========================================

# ------------------------------------------
# Server Configuration
# ------------------------------------------
HOST=127.0.0.1
PORT=8000
DEBUG=True

# ------------------------------------------
# Database Configuration
# ------------------------------------------
DATABASE_URL=sqlite:///./app/database/rescue.db

# ------------------------------------------
# Offline AI (Ollama)
# ------------------------------------------
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT=120

# ------------------------------------------
# Offline Computer Vision (YOLO)
# ------------------------------------------
YOLO_MODEL_PATH=./app/models/yolo/yolov8n.pt

# ------------------------------------------
# Offline OCR
# ------------------------------------------
EASYOCR_LANGUAGES=en,hi

# ------------------------------------------
# Offline Speech-to-Text (Vosk)
# ------------------------------------------
VOSK_MODEL_PATH=./app/models/vosk/model

# ------------------------------------------
# Offline Text-to-Speech (Piper)
# ------------------------------------------
PIPER_VOICE_PATH=./app/models/piper/en_US-lessac-medium.onnx

# ------------------------------------------
# RescueAI Configuration
# ------------------------------------------
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,hi

# ------------------------------------------
# Application Mode
# ------------------------------------------
OFFLINE_MODE=True
ENABLE_VOICE_ASSISTANT=True
ENABLE_OCR=True
ENABLE_OBJECT_DETECTION=True
ENABLE_TTS=True
ENABLE_CHATBOT=True

# ------------------------------------------
# Knowledge Base
# ------------------------------------------
KNOWLEDGE_BASE_PATH=./app/knowledge

# ------------------------------------------
# Logging
# ------------------------------------------
LOG_LEVEL=INFO